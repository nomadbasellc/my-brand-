{% style %}
  {% # NOMADBASE brand typeface: Satoshi (self-hosted in assets) %}
  @font-face {
    font-family: "Satoshi";
    src: url({{ 'Satoshi-Regular.otf' | asset_url }}) format("opentype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Satoshi";
    src: url({{ 'Satoshi-Medium.otf' | asset_url }}) format("opentype");
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Satoshi";
    src: url({{ 'Satoshi-Bold.otf' | asset_url }}) format("opentype");
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Satoshi";
    src: url({{ 'Satoshi-Black.otf' | asset_url }}) format("opentype");
    font-weight: 800 900;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --font-primary--family: "Satoshi", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    --font-primary--style: normal;
    --font-primary--weight: 400;
    --page-width: {{ settings.max_page_width }};
    --page-margin: {{ settings.min_page_margin }}px;
    --color-background: {{ settings.background_color }};
    --color-foreground: {{ settings.foreground_color }};
    --style-border-radius-inputs: {{ settings.input_corner_radius }}px;
  }
{% endstyle %}
