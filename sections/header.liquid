<header class="nb-header full-width">
  <div class="nb-container nb-header__inner">
    <a class="nb-header__brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: 400 | image_tag: alt: shop.name, class: 'nb-header__logo' }}
      {% else %}
        <img class="nb-header__logo" src="{{ 'nomadbase-logo.png' | asset_url }}" alt="{{ shop.name }}" width="230" height="60">
      {% endif %}
    </a>

    <nav class="nb-header__nav">
      {% if section.settings.menu.links != blank %}
        {% for link in section.settings.menu.links %}
          <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
        {% endfor %}
      {% else %}
        <a href="/#features">Features</a>
        <a href="/#faq">FAQ</a>
        <a href="/pages/about">About</a>
      {% endif %}
    </nav>

    <div class="nb-header__actions">
      {% if shop.customer_accounts_enabled %}
        <shopify-account class="nb-header__icon" menu="{{ section.settings.customer_account_menu }}">
          {{ 'icon-account.svg' | inline_asset_content }}
        </shopify-account>
      {% endif %}

      <a class="nb-header__icon" href="{{ routes.cart_url }}" aria-label="Cart">
        {% if cart.item_count > 0 %}
          <sup class="nb-header__count">{{ cart.item_count }}</sup>
        {% endif %}
        {{ 'icon-cart.svg' | inline_asset_content }}
      </a>

      {% if section.settings.cta_text != blank %}
        <a class="nb-btn nb-btn--primary nb-header__cta" href="{{ section.settings.cta_url | default: '#' }}">
          {{ section.settings.cta_text }}
        </a>
      {% endif %}
    </div>
  </div>
</header>

{% comment %} Make the section wrapper itself sticky so the header holds through full-page scroll {% endcomment %}
{% style %}
  #shopify-section-{{ section.id }} {
    position: sticky;
    top: 0;
    z-index: 50;
  }
{% endstyle %}

{% stylesheet %}
  .nb-header {
    background: color-mix(in srgb, var(--nb-bg) 60%, transparent);
    backdrop-filter: blur(22px) saturate(165%);
    -webkit-backdrop-filter: blur(22px) saturate(165%);
    border-bottom: 1px solid var(--nb-line);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .nb-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 4.5rem;
  }
  .nb-header__brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: var(--nb-text);
    flex-shrink: 0;
  }
  .nb-header__logo {
    width: auto;
    height: 1.5rem;
    display: block;
  }
  .nb-header__nav {
    display: flex;
    gap: 1.75rem;
    margin-inline: auto;
  }
  .nb-header__nav a {
    color: var(--nb-muted);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.15s ease;
  }
  .nb-header__nav a:hover,
  .nb-header__nav a[aria-current="page"] {
    color: var(--nb-text);
  }
  .nb-header__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }
  .nb-header__icon {
    position: relative;
    display: inline-flex;
    color: var(--nb-text);
    text-decoration: none;
  }
  .nb-header__icon svg {
    width: 1.4rem;
    height: 1.4rem;
  }
  .nb-header__count {
    position: absolute;
    top: -0.5rem;
    left: 100%;
    transform: translateX(-40%);
    font-family: var(--nb-mono);
    font-size: 0.62rem;
    font-weight: 700;
    line-height: 1;
    padding: 0.15rem 0.3rem;
    border-radius: 999px;
    background: var(--nb-gradient);
    color: #fff;
  }
  .nb-header__cta {
    padding: 0.65rem 1.1rem;
    border-radius: 10px;
    font-size: 0.9rem;
  }

  @media (max-width: 990px) {
    .nb-header__nav {
      display: none;
    }
  }
  @media (max-width: 600px) {
    .nb-header__cta {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (optional — falls back to store name)"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Get Yours"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
