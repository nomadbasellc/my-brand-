{% comment %}
  Nomadbase hero. Two layouts via the "layout" setting:
    - stacked: copy + buttons on top, large product below (centered)
    - split:   copy left, product right (two columns)
  Media priority: video > image > default transparent render.
{% endcomment %}

<div class="nb-hero nb-hero--{{ section.settings.layout }} full-width">
  <div class="nb-container nb-hero__grid">
    <div class="nb-hero__copy">
      {% if section.settings.eyebrow != blank %}
        <p class="nb-eyebrow nb-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      <h1 class="nb-display nb-hero__title">{{ section.settings.heading }}</h1>

      {% if section.settings.subheading != blank %}
        <p class="nb-lead nb-hero__lead">{{ section.settings.subheading }}</p>
      {% endif %}

      <div class="nb-hero__actions">
        {% if section.settings.primary_text != blank %}
          <a class="nb-btn nb-btn--primary" href="{{ section.settings.primary_url | default: '#' }}">
            {{ section.settings.primary_text }}
          </a>
        {% endif %}
        {% if section.settings.secondary_text != blank %}
          <a class="nb-btn nb-btn--ghost" href="{{ section.settings.secondary_url | default: '#' }}">
            {{ section.settings.secondary_text }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="nb-hero__media">
      {% if section.settings.video != blank %}
        {{ section.settings.video | video_tag: image_size: '1200x', loop: true, autoplay: true, muted: true, controls: false, class: 'nb-hero__asset' }}
      {% elsif section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1600 | image_tag: class: 'nb-hero__asset', widths: '700, 1000, 1300, 1600', sizes: '(max-width: 900px) 100vw, 60vw', alt: section.settings.heading }}
      {% else %}
        <img
          class="nb-hero__asset"
          src="{{ 'nomadbase-product-hero.png' | asset_url }}"
          alt="Nomadbase lapboard"
          width="1500"
          height="699"
          fetchpriority="high"
        >
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .nb-hero {
    position: relative;
    overflow: hidden;
  }
  .nb-hero__grid {
    position: relative;
    z-index: 1;
  }
  .nb-hero__eyebrow {
    margin-bottom: 1.5rem;
  }
  .nb-hero__title {
    font-size: clamp(1.85rem, 3.4vw, 2.9rem);
  }
  .nb-hero__lead {
    margin-top: 1.5rem;
  }
  .nb-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.25rem;
  }
  .nb-hero__media {
    position: relative;
  }
  .nb-hero__asset {
    position: relative;
    z-index: 1;
    height: auto;
    object-fit: contain;
  }

  /* ---- Split layout (copy left, product right) ---- */
  .nb-hero--split {
    background:
      radial-gradient(58% 72% at 72% 42%, rgba(150, 184, 191, 0.22), rgba(120, 160, 168, 0.06) 42%, transparent 66%),
      radial-gradient(90% 120% at 50% -10%, rgba(94, 139, 149, 0.1), transparent 55%),
      var(--nb-bg);
  }
  .nb-hero--split .nb-hero__grid {
    display: grid;
    grid-template-columns: 0.92fr 1.18fr;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    padding-block: clamp(3.5rem, 8vw, 7rem);
  }
  .nb-hero--split .nb-hero__title {
    max-width: 15ch;
  }
  .nb-hero--split .nb-hero__lead {
    max-width: 42ch;
  }
  .nb-hero--split .nb-hero__media {
    display: grid;
    place-items: center;
    min-height: 300px;
  }
  .nb-hero--split .nb-hero__asset {
    width: 122%;
    max-width: 122%;
    margin-inline: -11%;
  }

  /* ---- Stacked layout (copy on top, product below) ---- */
  .nb-hero--stacked {
    background:
      radial-gradient(52% 46% at 50% 74%, rgba(150, 184, 191, 0.24), rgba(120, 160, 168, 0.06) 45%, transparent 68%),
      radial-gradient(90% 60% at 50% -8%, rgba(94, 139, 149, 0.09), transparent 55%),
      var(--nb-bg);
  }
  .nb-hero--stacked .nb-hero__grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: clamp(2rem, 5vw, 3.5rem);
    padding-block: clamp(3rem, 6vw, 5rem) 0;
  }
  .nb-hero--stacked .nb-hero__copy {
    max-width: 40rem;
  }
  .nb-hero--stacked .nb-hero__title {
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    margin-inline: auto;
    max-width: 20ch;
  }
  .nb-hero--stacked .nb-hero__lead {
    margin-inline: auto;
    max-width: 52ch;
  }
  .nb-hero--stacked .nb-hero__actions {
    justify-content: center;
  }
  .nb-hero--stacked .nb-hero__media {
    width: 100%;
    display: grid;
    place-items: center;
  }
  .nb-hero--stacked .nb-hero__asset {
    width: min(112%, 1120px);
    max-width: 112%;
  }

  @media (max-width: 900px) {
    .nb-hero--split .nb-hero__grid {
      grid-template-columns: 1fr;
    }
    .nb-hero--split .nb-hero__media {
      order: -1;
      min-height: 0;
    }
    .nb-hero--split .nb-hero__asset {
      width: 108%;
      max-width: 108%;
      margin-inline: -4%;
    }
    .nb-hero--split .nb-hero__title {
      max-width: 20ch;
    }
    .nb-hero--stacked .nb-hero__asset {
      width: 118%;
      max-width: 118%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "stacked", "label": "Stacked (product below)" },
        { "value": "split", "label": "Split (product beside)" }
      ],
      "default": "stacked"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": ""
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Take your whole setup off the wall."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "A modular lapboard that clamps your keyboard and pins your mouse with magnets — so nothing slides, even when the surface isn't flat. A real desk, wherever you are."
    },
    {
      "type": "text",
      "id": "primary_text",
      "label": "Primary button text",
      "default": "Get Yours"
    },
    {
      "type": "url",
      "id": "primary_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Secondary button text",
      "default": ""
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "Secondary button URL"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image (transparent PNG looks best)"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Product video (overrides image)"
    }
  ],
  "presets": [
    { "name": "Hero" }
  ]
}
{% endschema %}
