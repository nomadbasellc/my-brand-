{% comment %} sync-1784475534 {% endcomment %}
{% comment %}
  Nomadbase hero.
  - layout: stacked (product below) or split (product beside)
  - style: refined or bold (techy) — bold adds a signal accent, mono/sharp
    button with a hover tick, heavier headline, and a spec-stats strip
  Media priority: video > image > default transparent render.
{% endcomment %}

<div class="nb-hero nb-hero--{{ section.settings.layout }} nb-hero--style-{{ section.settings.style }} full-width">
  <div class="nb-container nb-hero__grid">
    <div class="nb-hero__copy">
      {% if section.settings.eyebrow != blank %}
        <p class="nb-eyebrow nb-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      <h1 class="nb-display nb-hero__title">{{ section.settings.heading }}</h1>

      {% if section.settings.subheading != blank %}
        <p class="nb-lead nb-hero__lead">{{ section.settings.subheading }}</p>
      {% endif %}

      <div class="nb-hero__actions">
        {% if section.settings.primary_text != blank %}
          <a class="nb-btn nb-btn--primary nb-hero__cta" href="{{ section.settings.primary_url | default: '#' }}">
            <span>{{ section.settings.primary_text }}</span>
          </a>
        {% endif %}
        {% if section.settings.secondary_text != blank %}
          <a class="nb-btn nb-btn--ghost" href="{{ section.settings.secondary_url | default: '#' }}">
            {{ section.settings.secondary_text }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="nb-hero__media">
      {% if section.settings.video != blank %}
        {{ section.settings.video | video_tag: image_size: '1200x', loop: true, autoplay: true, muted: true, controls: false, class: 'nb-hero__asset' }}
      {% elsif section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1600 | image_tag: class: 'nb-hero__asset', widths: '700, 1000, 1300, 1600', sizes: '(max-width: 900px) 100vw, 60vw', alt: section.settings.heading }}
      {% else %}
        <img
          class="nb-hero__asset"
          src="{{ 'nomadbase-product-hero.png' | asset_url }}"
          alt="Nomadbase lapboard"
          width="1500"
          height="699"
          fetchpriority="high"
        >
      {% endif %}
    </div>
  </div>

  {% if section.settings.show_specs %}
    <div class="nb-container nb-hero__specs">
      {% for i in (1..4) %}
        {% assign v = 'stat' | append: i | append: '_value' %}
        {% assign l = 'stat' | append: i | append: '_label' %}
        {% assign val = section.settings[v] %}
        {% assign lab = section.settings[l] %}
        {% if val != blank %}
          <div class="nb-hero__spec">
            <span class="nb-hero__spec-val">{{ val }}</span>
            <span class="nb-hero__spec-label">{{ lab }}</span>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .nb-hero {
    position: relative;
    overflow: hidden;
  }
  .nb-hero__grid {
    position: relative;
    z-index: 1;
  }
  .nb-hero__eyebrow {
    margin-bottom: 1.5rem;
  }
  .nb-hero__title {
    font-size: clamp(1.85rem, 3.4vw, 2.9rem);
  }
  .nb-hero__lead {
    margin-top: 1.5rem;
  }
  .nb-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.25rem;
  }
  .nb-hero__media {
    position: relative;
  }
  .nb-hero__asset {
    position: relative;
    z-index: 1;
    height: auto;
    object-fit: contain;
  }

  /* ---- Split layout ---- */
  .nb-hero--split {
    background:
      radial-gradient(58% 72% at 72% 42%, rgba(150, 184, 191, 0.22), rgba(120, 160, 168, 0.06) 42%, transparent 66%),
      radial-gradient(90% 120% at 50% -10%, rgba(94, 139, 149, 0.1), transparent 55%),
      var(--nb-bg);
  }
  .nb-hero--split .nb-hero__grid {
    display: grid;
    grid-template-columns: 0.92fr 1.18fr;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    padding-block: clamp(3.5rem, 8vw, 7rem);
  }
  .nb-hero--split .nb-hero__title {
    max-width: 15ch;
  }
  .nb-hero--split .nb-hero__lead {
    max-width: 42ch;
  }
  .nb-hero--split .nb-hero__media {
    display: grid;
    place-items: center;
    min-height: 300px;
  }
  .nb-hero--split .nb-hero__asset {
    width: 122%;
    max-width: 122%;
    margin-inline: -11%;
  }

  /* ---- Stacked layout ---- */
  .nb-hero--stacked {
    background:
      radial-gradient(52% 46% at 50% 74%, rgba(150, 184, 191, 0.24), rgba(120, 160, 168, 0.06) 45%, transparent 68%),
      radial-gradient(90% 60% at 50% -8%, rgba(94, 139, 149, 0.09), transparent 55%),
      var(--nb-bg);
  }
  .nb-hero--stacked .nb-hero__grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: clamp(2rem, 5vw, 3.5rem);
    padding-block: clamp(3rem, 6vw, 5rem) 0;
  }
  .nb-hero--stacked .nb-hero__copy {
    max-width: 40rem;
  }
  .nb-hero--stacked .nb-hero__title {
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    margin-inline: auto;
    max-width: 20ch;
  }
  .nb-hero--stacked .nb-hero__lead {
    margin-inline: auto;
    max-width: 52ch;
  }
  .nb-hero--stacked .nb-hero__actions {
    justify-content: center;
  }
  .nb-hero--stacked .nb-hero__media {
    width: 100%;
    display: grid;
    place-items: center;
  }
  .nb-hero--stacked .nb-hero__asset {
    width: min(112%, 1120px);
    max-width: 112%;
  }

  /* ---- Spec-stats strip ---- */
  .nb-hero__specs {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--nb-line);
    margin-top: clamp(2rem, 5vw, 3.5rem);
  }
  .nb-hero__spec {
    padding: clamp(1rem, 2.5vw, 1.5rem) 0;
    padding-inline-start: clamp(1rem, 2vw, 1.5rem);
    border-inline-start: 1px solid var(--nb-line);
  }
  .nb-hero__spec:first-child {
    border-inline-start: 0;
    padding-inline-start: 0;
  }
  .nb-hero__spec-val {
    display: block;
    font-family: var(--nb-mono);
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .nb-hero__spec-label {
    display: block;
    font-family: var(--nb-mono);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.64rem;
    color: var(--nb-muted);
    margin-top: 0.55rem;
  }

  /* =========================================================
     BOLD (techy) style — layered on top of the above
     ========================================================= */
  .nb-hero--style-bold {
    --nb-signal: #35e0c4;
  }
  .nb-hero--style-bold .nb-hero__title {
    font-weight: 800;
    letter-spacing: -0.035em;
  }
  /* Signal-accent, mono, sharp-cornered CTA with a hover tick */
  .nb-hero--style-bold .nb-hero__cta {
    background: var(--nb-signal);
    color: #05130f;
    border-radius: 4px;
    font-family: var(--nb-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    padding-inline: 1.35rem;
  }
  .nb-hero--style-bold .nb-hero__cta::after {
    content: "→";
    margin-inline-start: 0.15rem;
    transition: transform 0.15s ease;
  }
  .nb-hero--style-bold .nb-hero__cta:hover {
    opacity: 1;
    box-shadow: 0 0 0 1px var(--nb-signal), 0 0 24px rgba(53, 224, 196, 0.35);
  }
  .nb-hero--style-bold .nb-hero__cta:hover::after {
    transform: translateX(4px);
  }
  .nb-hero--style-bold .nb-hero__spec-val {
    color: var(--nb-signal);
  }

  @media (max-width: 900px) {
    .nb-hero--split .nb-hero__grid {
      grid-template-columns: 1fr;
    }
    .nb-hero--split .nb-hero__media {
      order: -1;
      min-height: 0;
    }
    .nb-hero--split .nb-hero__asset {
      width: 108%;
      max-width: 108%;
      margin-inline: -4%;
    }
    .nb-hero--split .nb-hero__title {
      max-width: 20ch;
    }
    .nb-hero--stacked .nb-hero__asset {
      width: 118%;
      max-width: 118%;
    }
  }
  @media (max-width: 620px) {
    .nb-hero__specs {
      grid-template-columns: repeat(2, 1fr);
      gap: 1px;
    }
    .nb-hero__spec:nth-child(3) {
      border-inline-start: 0;
      padding-inline-start: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "select",
      "id": "style",
      "label": "Design style",
      "options": [
        { "value": "bold", "label": "Bold (techy)" },
        { "value": "refined", "label": "Refined" }
      ],
      "default": "refined"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "stacked", "label": "Stacked (product below)" },
        { "value": "split", "label": "Split (product beside)" }
      ],
      "default": "stacked"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Take your whole setup off the wall." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "A modular lapboard that clamps your keyboard and pins your mouse with magnets — so nothing slides, even when the surface isn't flat. A real desk, wherever you are." },
    { "type": "text", "id": "primary_text", "label": "Primary button text", "default": "Get Yours" },
    { "type": "url", "id": "primary_url", "label": "Primary button URL" },
    { "type": "text", "id": "secondary_text", "label": "Secondary button text" },
    { "type": "url", "id": "secondary_url", "label": "Secondary button URL" },
    {
      "type": "header",
      "content": "Spec strip"
    },
    { "type": "checkbox", "id": "show_specs", "label": "Show spec strip", "default": false },
    { "type": "text", "id": "stat1_value", "label": "Stat 1 value", "default": "~12h" },
    { "type": "text", "id": "stat1_label", "label": "Stat 1 label", "default": "Print time per board" },
    { "type": "text", "id": "stat2_value", "label": "Stat 2 value", "default": "1×1" },
    { "type": "text", "id": "stat2_label", "label": "Stat 2 label", "default": "Printed & assembled by hand" },
    { "type": "text", "id": "stat3_value", "label": "Stat 3 value", "default": "0°" },
    { "type": "text", "id": "stat3_label", "label": "Stat 3 label", "default": "Flat surface required" },
    { "type": "text", "id": "stat4_value", "label": "Stat 4 value", "default": "∞" },
    { "type": "text", "id": "stat4_label", "label": "Stat 4 label", "default": "Color & finish combos" },
    {
      "type": "header",
      "content": "Media"
    },
    { "type": "image_picker", "id": "image", "label": "Product image (transparent PNG looks best)" },
    { "type": "video", "id": "video", "label": "Product video (overrides image)" }
  ],
  "presets": [
    { "name": "Hero" }
  ]
}
{% endschema %}
