{% comment %}
  NOMADBASE hero. Copy on the left, a large "floating" product on the right
  with a soft light behind it. Media priority: video > image > default render.
  The asset edges are feathered so a render with a background melts into the page;
  for the cleanest look, supply a transparent PNG (or a video).
{% endcomment %}

<div class="nb-hero full-width">
  <div class="nb-container nb-hero__grid">
    <div class="nb-hero__copy">
      {% if section.settings.eyebrow != blank %}
        <p class="nb-eyebrow nb-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      <h1 class="nb-display nb-hero__title">{{ section.settings.heading }}</h1>

      {% if section.settings.subheading != blank %}
        <p class="nb-lead nb-hero__lead">{{ section.settings.subheading }}</p>
      {% endif %}

      <div class="nb-hero__actions">
        {% if section.settings.primary_text != blank %}
          <a class="nb-btn nb-btn--primary" href="{{ section.settings.primary_url | default: '#' }}">
            {{ section.settings.primary_text }}
          </a>
        {% endif %}
        {% if section.settings.secondary_text != blank %}
          <a class="nb-btn nb-btn--ghost" href="{{ section.settings.secondary_url | default: '#' }}">
            {{ section.settings.secondary_text }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="nb-hero__media">
      {% if section.settings.video != blank %}
        {{ section.settings.video | video_tag: image_size: '1200x', loop: true, autoplay: true, muted: true, controls: false, class: 'nb-hero__asset' }}
      {% elsif section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1600 | image_tag: class: 'nb-hero__asset', widths: '700, 1000, 1300, 1600', sizes: '(max-width: 900px) 100vw, 60vw', alt: section.settings.heading }}
      {% else %}
        <img
          class="nb-hero__asset"
          src="{{ 'nomadbase-product-hero.png' | asset_url }}"
          alt="NOMADBASE lapboard"
          width="1500"
          height="699"
          fetchpriority="high"
        >
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .nb-hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(58% 72% at 72% 42%, rgba(150, 184, 191, 0.22), rgba(120, 160, 168, 0.06) 42%, transparent 66%),
      radial-gradient(90% 120% at 50% -10%, rgba(94, 139, 149, 0.1), transparent 55%),
      var(--nb-bg);
  }
  .nb-hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 0.92fr 1.18fr;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    padding-block: clamp(3.5rem, 8vw, 7rem);
  }
  .nb-hero__eyebrow {
    margin-bottom: 1.5rem;
  }
  .nb-hero__title {
    font-size: clamp(1.85rem, 3.4vw, 2.9rem);
    max-width: 15ch;
  }
  .nb-hero__lead {
    margin-top: 1.5rem;
    max-width: 42ch;
  }
  .nb-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.25rem;
  }

  /* Media: large transparent product; the light lives on the section bg */
  .nb-hero__media {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 300px;
  }
  .nb-hero__asset {
    position: relative;
    z-index: 1;
    width: 122%;
    max-width: 122%;
    height: auto;
    margin-inline: -11%;
    object-fit: contain;
  }

  @media (max-width: 900px) {
    .nb-hero__grid {
      grid-template-columns: 1fr;
    }
    .nb-hero__media {
      order: -1;
      min-height: 0;
    }
    .nb-hero__asset {
      width: 108%;
      max-width: 108%;
      margin-inline: -4%;
    }
    .nb-hero__title {
      max-width: 20ch;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Made to order · Printed by hand · One at a time"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Take your whole setup off the wall."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "A modular lapboard that clamps your keyboard and pins your mouse with magnets — so nothing slides, even when the surface isn't flat. A real desk, wherever you are."
    },
    {
      "type": "text",
      "id": "primary_text",
      "label": "Primary button text",
      "default": "Build yours"
    },
    {
      "type": "url",
      "id": "primary_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Secondary button text",
      "default": "See how it works"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "Secondary button URL"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image (transparent PNG looks best)"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Product video (overrides image)"
    }
  ],
  "presets": [
    { "name": "Hero" }
  ]
}
{% endschema %}
