{% comment %}
  Nomadbase FAQ. Native <details>/<summary> accordion — accessible, no JS.
  Each Q&A is a section block.
{% endcomment %}

<div id="faq" class="nb-faq full-width nb-scheme nb-scheme--{{ section.settings.color_scheme }} nb-section">
  <div class="nb-container nb-faq__grid">
    <div class="nb-faq__head">
      {% if section.settings.eyebrow != blank %}
        <p class="nb-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="nb-h2 nb-faq__title">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.support_text != blank %}
        <p class="nb-lead nb-faq__support">{{ section.settings.support_text }}</p>
      {% endif %}
    </div>

    <div class="nb-faq__list">
      {% for block in section.blocks %}
        <details class="nb-faq__item" {{ block.shopify_attributes }}>
          <summary class="nb-faq__q">
            <span>{{ block.settings.question }}</span>
            <span class="nb-faq__mark" aria-hidden="true"></span>
          </summary>
          <div class="nb-faq__a">{{ block.settings.answer }}</div>
        </details>
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .nb-faq__grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .nb-faq__title {
    margin-top: 1rem;
  }
  .nb-faq__support {
    margin-top: 1.25rem;
  }
  .nb-faq__item {
    border-bottom: 1px solid var(--nb-line);
  }
  .nb-faq__item:first-child {
    border-top: 1px solid var(--nb-line);
  }
  .nb-faq__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    cursor: pointer;
    font-weight: 700;
    font-size: 1.05rem;
    list-style: none;
  }
  .nb-faq__q::-webkit-details-marker {
    display: none;
  }
  .nb-faq__mark {
    position: relative;
    flex-shrink: 0;
    width: 1rem;
    height: 1rem;
  }
  .nb-faq__mark::before,
  .nb-faq__mark::after {
    content: "";
    position: absolute;
    background: var(--nb-teal);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .nb-faq__mark::before {
    top: 50%;
    left: 0;
    width: 100%;
    height: 2px;
    transform: translateY(-50%);
  }
  .nb-faq__mark::after {
    left: 50%;
    top: 0;
    width: 2px;
    height: 100%;
    transform: translateX(-50%);
  }
  .nb-faq__item[open] .nb-faq__mark::after {
    opacity: 0;
    transform: translateX(-50%) scaleY(0);
  }
  .nb-faq__a {
    padding: 0 0 1.35rem;
    color: var(--nb-muted);
    line-height: 1.6;
    max-width: 60ch;
  }

  @media (max-width: 820px) {
    .nb-faq__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "dark", "label": "Dark" }
      ],
      "default": "light"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Good questions" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Before you build one." },
    { "type": "textarea", "id": "support_text", "label": "Support text", "default": "Still unsure? Reach out — a real person who makes the boards will answer." }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Q&A",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How long until it ships?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "Every board is printed to order, so there's a short wait — usually about two weeks. You're not getting one off a shelf; you're getting yours." }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "qa", "settings": { "question": "How long until it ships?", "answer": "Every board is printed to order, so there's a short wait — usually about two weeks. You're not getting one off a shelf; you're getting yours." } },
        { "type": "qa", "settings": { "question": "Will my keyboard fit?", "answer": "Almost certainly. The clamp is adjustable from 60% to full-size and isn't brand-specific — mechanical or membrane, wired or wireless." } },
        { "type": "qa", "settings": { "question": "How does the mouse stay put?", "answer": "A slim magnet puck rides under your mouse and pulls to the board. You can tune the strength from 'rests there' to 'locked down' for fast flicks." } },
        { "type": "qa", "settings": { "question": "What's your return policy?", "answer": "30 days. If it doesn't work for how you work, send it back for a full refund." } },
        { "type": "qa", "settings": { "question": "Curated vs Custom — what's the difference?", "answer": "Curated is a color and finish combo we've already dialed in. Custom lets you choose color, material, finish, hand, and plate layout. Both are made to order." } },
        { "type": "qa", "settings": { "question": "Is it covered by a warranty?", "answer": "Yes — one year against defects. We make each board by hand and stand behind it." } }
      ]
    }
  ]
}
{% endschema %}
