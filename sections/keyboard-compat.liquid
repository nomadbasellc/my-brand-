{% comment %}
  Nomadbase keyboard compatibility. Centered intro, then a centered
  "logo wall" of compatible brands. Each brand is a section block with an
  optional logo image; falls back to the brand name until logos are added.
{% endcomment %}

<div class="nb-kbc full-width nb-scheme nb-scheme--{{ section.settings.color_scheme }} nb-section">
  <div class="nb-container nb-kbc__head">
    {% if section.settings.eyebrow != blank %}
      <p class="nb-eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="nb-h2 nb-kbc__title">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.body != blank %}
      <p class="nb-lead nb-kbc__body">{{ section.settings.body }}</p>
    {% endif %}
    {% if section.settings.sizes != blank %}
      <ul class="nb-kbc__sizes">
        {% assign sizes = section.settings.sizes | split: ',' %}
        {% for size in sizes %}
          <li class="nb-kbc__size">{{ size | strip }}</li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>

  <div class="nb-container">
    {% if section.settings.brands_label != blank %}
      <p class="nb-kbc__brands-label">{{ section.settings.brands_label }}</p>
    {% endif %}

    <div class="nb-kbc__logos">
      {% for block in section.blocks %}
        <div class="nb-kbc__logo" {{ block.shopify_attributes }}>
          {% if block.settings.logo != blank %}
            {{ block.settings.logo | image_url: width: 300 | image_tag: class: 'nb-kbc__logo-img', loading: 'lazy', alt: block.settings.name }}
          {% elsif block.settings.logo_asset != blank %}
            <img class="nb-kbc__logo-img" src="{{ block.settings.logo_asset | asset_url }}" alt="{{ block.settings.name }}" loading="lazy">
          {% else %}
            <span class="nb-kbc__logo-name">{{ block.settings.name }}</span>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if section.settings.footnote != blank %}
      <p class="nb-kbc__footnote">{{ section.settings.footnote }}</p>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .nb-kbc__head {
    text-align: center;
    max-width: 46rem;
    margin: 0 auto clamp(2.5rem, 5vw, 3.5rem);
  }
  .nb-kbc__title {
    margin-top: 1rem;
  }
  .nb-kbc__body {
    margin: 1.25rem auto 0;
  }
  .nb-kbc__sizes {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
    list-style: none;
    padding: 0;
    margin: 1.75rem 0 0;
  }
  .nb-kbc__size {
    font-family: var(--nb-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    border: 1px solid var(--nb-teal);
    color: var(--nb-label);
  }
  .nb-kbc__brands-label {
    text-align: center;
    font-family: var(--nb-mono);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.7rem;
    color: var(--nb-muted);
    margin: 0 0 1.25rem;
  }
  .nb-kbc__logos {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: clamp(1.75rem, 4vw, 3rem) clamp(2.25rem, 5vw, 4rem);
    max-width: 64rem;
    margin-inline: auto;
  }
  .nb-kbc__logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .nb-kbc__logo-name {
    font-weight: 600;
    font-size: 0.98rem;
    color: var(--nb-muted);
  }
  /* Logos share a uniform canvas, so a fixed height renders them all the
     same size. object-fit keeps them crisp and centered. */
  .nb-kbc__logo-img {
    height: 34px;
    width: auto;
    max-width: 150px;
    object-fit: contain;
    opacity: 0.72;
    transition: opacity 0.15s ease;
  }
  .nb-kbc__logo:hover .nb-kbc__logo-img {
    opacity: 1;
  }
  .nb-kbc__footnote {
    text-align: center;
    max-width: 60ch;
    margin: 1.5rem auto 0;
    color: var(--nb-muted);
    font-size: 0.9rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Keyboard compatibility",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "dark", "label": "Dark" }
      ],
      "default": "dark"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Fits your board" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Made for the keyboard you already love." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "The clamp grips any board from 60% to full-size — mechanical or membrane, wired or wireless. If it sits on a desk, it locks to Nomadbase." },
    { "type": "text", "id": "sizes", "label": "Sizes (comma-separated)", "default": "60%, 65%, 75%, TKL, Full-size" },
    { "type": "text", "id": "brands_label", "label": "Brands label", "default": "Tested with boards from" },
    { "type": "textarea", "id": "footnote", "label": "Footnote", "default": "Not an exhaustive list — the adjustable clamp isn't brand-specific. Yours almost certainly fits." }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo (optional)" },
        { "type": "text", "id": "logo_asset", "label": "Logo asset filename (e.g. logo-keychron.png)" },
        { "type": "text", "id": "name", "label": "Brand name", "default": "Keychron" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Keyboard compatibility",
      "blocks": [
        { "type": "brand", "settings": { "name": "Keychron" } },
        { "type": "brand", "settings": { "name": "Apple Magic Keyboard" } },
        { "type": "brand", "settings": { "name": "Logitech" } },
        { "type": "brand", "settings": { "name": "NuPhy" } },
        { "type": "brand", "settings": { "name": "Ducky" } },
        { "type": "brand", "settings": { "name": "Royal Kludge" } },
        { "type": "brand", "settings": { "name": "Corsair" } },
        { "type": "brand", "settings": { "name": "HHKB" } }
      ]
    }
  ]
}
{% endschema %}
