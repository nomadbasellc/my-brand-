{% comment %}
  Nomadbase embedded PDP. Connect a product to get an in-page product block:
  variant-swapping media, option selectors (e.g. colour), live price, and a
  "Buy it now" button that adds the variant and goes straight to checkout
  (skipping the cart). Until a product is connected, shows a short prompt.
{% endcomment %}

{% assign product = section.settings.product %}

<div id="shop" class="nb-pdp full-width nb-scheme nb-scheme--{{ section.settings.color_scheme }} nb-section">
  <div class="nb-container nb-pdp__head">
    {% if section.settings.eyebrow != blank %}
      <p class="nb-eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="nb-h2 nb-pdp__title">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.intro != blank %}
      <p class="nb-lead nb-pdp__intro">{{ section.settings.intro }}</p>
    {% endif %}
  </div>

  {% if product != blank %}
    {% assign current = product.selected_or_first_available_variant %}
    <div class="nb-container nb-pdp__grid" data-nb-pdp>
      <div class="nb-pdp__media">
        <img
          class="nb-pdp__img"
          data-nb-image
          src="{{ current.featured_image | default: product.featured_image | image_url: width: 1400 }}"
          alt="{{ product.title | escape }}"
          width="1400"
          height="1050"
        >
      </div>

      <div class="nb-pdp__panel">
        <h3 class="nb-pdp__name">{{ product.title }}</h3>
        <p class="nb-pdp__price" data-nb-price>{{ current.price | money }}</p>

        {% form 'product', product, class: 'nb-pdp__form' %}
          {% for option in product.options_with_values %}
            {% unless option.name == 'Title' and option.values.size == 1 %}
              <fieldset class="nb-pdp__option">
                <legend class="nb-pdp__option-label">{{ option.name }}</legend>
                <div class="nb-pdp__values">
                  {% for value in option.values %}
                    <label class="nb-pdp__opt">
                      <input
                        type="radio"
                        name="option{{ option.position }}"
                        value="{{ value | escape }}"
                        data-position="{{ option.position }}"
                        {% if option.selected_value == value %}checked{% endif %}
                      >
                      <span>{{ value }}</span>
                    </label>
                  {% endfor %}
                </div>
              </fieldset>
            {% endunless %}
          {% endfor %}

          <input type="hidden" name="id" value="{{ current.id }}" data-nb-id>

          <div class="nb-pdp__actions">
            <button type="button" class="nb-btn nb-btn--primary nb-pdp__buy" data-nb-buy {% unless current.available %}disabled{% endunless %}>
              {% if current.available %}Get Yours{% else %}Sold out{% endif %}
            </button>
            <button type="submit" class="nb-btn nb-btn--ghost nb-pdp__add" data-nb-add {% unless current.available %}disabled{% endunless %}>
              Add to cart
            </button>
          </div>
        {% endform %}

        {% if section.settings.note != blank %}
          <p class="nb-pdp__note">{{ section.settings.note }}</p>
        {% endif %}

        {% if product.description != blank %}
          <div class="nb-pdp__desc rte">{{ product.description }}</div>
        {% endif %}
      </div>
    </div>

    <script type="application/json" data-nb-variants>
      [
        {%- for v in product.variants -%}
          {
            "id": {{ v.id }},
            "options": {{ v.options | json }},
            "available": {{ v.available }},
            "price": {{ v.price | money | json }},
            "image": {% if v.featured_image %}{{ v.featured_image | image_url: width: 1400 | json }}{% else %}""{% endif %}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    </script>
  {% else %}
    <div class="nb-container nb-pdp__empty">
      <img class="nb-pdp__empty-img" src="{{ 'nomadbase-product-hero.png' | asset_url }}" alt="Nomadbase lapboard" width="1500" height="699">
      <div class="nb-pdp__empty-copy">
        <p class="nb-eyebrow">Almost ready</p>
        <p class="nb-pdp__empty-title">Connect a product to open checkout.</p>
        <p class="nb-lead">Create your Nomadbase product in Shopify with a colour option, then link it here in the theme editor. This block becomes a live, buy-it-now product — straight to checkout, no cart detour.</p>
      </div>
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .nb-pdp__head {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .nb-pdp__intro {
    max-width: 46rem;
  }
  .nb-pdp__title {
    margin-top: 1rem;
  }
  .nb-pdp__intro {
    margin-top: 1.25rem;
  }

  .nb-pdp__grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .nb-pdp__media {
    position: relative;
    border-radius: var(--nb-radius-lg);
    overflow: hidden;
    background: var(--nb-surface-2);
    border: 1px solid var(--nb-line);
    aspect-ratio: 4 / 3;
  }
  .nb-pdp__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .nb-pdp__name {
    font-weight: 700;
    font-size: clamp(1.4rem, 2.4vw, 1.9rem);
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
  }
  .nb-pdp__price {
    font-weight: 700;
    font-size: clamp(1.4rem, 2.4vw, 1.85rem);
    margin: 0 0 1.75rem;
    color: var(--nb-muted);
  }
  .nb-pdp__option {
    border: 0;
    padding: 0;
    margin: 0 0 1.5rem;
  }
  .nb-pdp__option-label {
    font-family: var(--nb-mono);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.72rem;
    color: var(--nb-muted);
    padding: 0;
    margin-bottom: 0.75rem;
  }
  .nb-pdp__values {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .nb-pdp__opt input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .nb-pdp__opt span {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.1rem;
    border-radius: var(--nb-radius);
    border: 1px solid var(--nb-line-strong);
    font-weight: 600;
    font-size: 0.92rem;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .nb-pdp__opt input:checked + span {
    border-color: var(--nb-teal);
    background: color-mix(in srgb, var(--nb-teal) 16%, transparent);
  }
  .nb-pdp__opt input:focus-visible + span {
    outline: 2px solid var(--nb-teal);
    outline-offset: 2px;
  }
  .nb-pdp__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.5rem;
  }
  .nb-pdp__buy {
    flex: 1 1 auto;
  }
  .nb-pdp__actions [disabled] {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .nb-pdp__note {
    margin-top: 1rem;
    color: var(--nb-muted);
    font-size: 0.85rem;
  }
  .nb-pdp__desc {
    margin-top: 1.5rem;
    color: var(--nb-muted);
    line-height: 1.6;
    border-top: 1px solid var(--nb-line);
    padding-top: 1.5rem;
  }

  /* Empty state */
  .nb-pdp__empty {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .nb-pdp__empty-img {
    width: 100%;
    height: auto;
    border-radius: var(--nb-radius-lg);
    border: 1px solid var(--nb-line);
  }
  .nb-pdp__empty-title {
    font-weight: 700;
    font-size: clamp(1.4rem, 2.4vw, 1.9rem);
    letter-spacing: -0.01em;
    margin: 1rem 0 1rem;
  }

  @media (max-width: 860px) {
    .nb-pdp__grid,
    .nb-pdp__empty {
      grid-template-columns: 1fr;
    }
    .nb-pdp__media,
    .nb-pdp__empty-img {
      order: -1;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    function initPdp(root) {
      var dataEl = root.querySelector('[data-nb-variants]');
      if (!dataEl) return;
      var variants;
      try {
        variants = JSON.parse(dataEl.textContent);
      } catch (e) {
        return;
      }
      var idInput = root.querySelector('[data-nb-id]');
      var priceEl = root.querySelector('[data-nb-price]');
      var buyBtn = root.querySelector('[data-nb-buy]');
      var addBtn = root.querySelector('[data-nb-add]');
      var imageEl = root.querySelector('[data-nb-image]');
      var form = root.querySelector('form');

      function selectedValues() {
        return Array.prototype.slice
          .call(root.querySelectorAll('input[type="radio"]:checked'))
          .sort(function (a, b) {
            return (a.dataset.position || 0) - (b.dataset.position || 0);
          })
          .map(function (i) {
            return i.value;
          });
      }

      function currentVariant() {
        var vals = selectedValues();
        if (!vals.length) return variants[0];
        return variants.find(function (v) {
          return (
            v.options.length === vals.length &&
            v.options.every(function (o, i) {
              return String(o) === String(vals[i]);
            })
          );
        });
      }

      function setDisabled(btn, state, label) {
        if (!btn) return;
        btn.disabled = state;
        if (label) btn.textContent = label;
      }

      function update() {
        var match = currentVariant();
        if (!match) {
          setDisabled(buyBtn, true, 'Unavailable');
          setDisabled(addBtn, true);
          return;
        }
        if (idInput) idInput.value = match.id;
        if (priceEl) priceEl.textContent = match.price;
        if (imageEl && match.image) imageEl.src = match.image;
        setDisabled(buyBtn, !match.available, match.available ? 'Get Yours' : 'Sold out');
        setDisabled(addBtn, !match.available);
      }

      function buyNow() {
        var match = currentVariant();
        if (!match || !match.available) return;
        setDisabled(buyBtn, true, 'Redirecting…');
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: [{ id: match.id, quantity: 1 }] })
        })
          .then(function () {
            window.location.href = '/checkout';
          })
          .catch(function () {
            setDisabled(buyBtn, false, 'Get Yours');
          });
      }

      root.querySelectorAll('input[type="radio"]').forEach(function (r) {
        r.addEventListener('change', update);
      });
      if (buyBtn) buyBtn.addEventListener('click', buyNow);

      update();
    }

    function initAll() {
      document.querySelectorAll('[data-nb-pdp]').forEach(initPdp);
    }

    if (document.readyState !== 'loading') {
      initAll();
    } else {
      document.addEventListener('DOMContentLoaded', initAll);
    }
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Product configurator",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "dark", "label": "Dark" }
      ],
      "default": "dark"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Yours to configure" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Build your board." },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Pick your color, we make it, it ships. Every board is printed to order — no shelf of finished units, just yours." },
    { "type": "product", "id": "product", "label": "Connected product" },
    { "type": "text", "id": "note", "label": "Note under buttons", "default": "Made to order — ships in ~2 weeks. Free shipping on all orders." }
  ],
  "presets": [
    { "name": "Product configurator" }
  ]
}
{% endschema %}
